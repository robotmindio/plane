# =============================================================================
# Plane Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and update the values before starting.
# Generate secrets with: openssl rand -hex 32
# IMPORTANT: Run ./setup.sh to auto-generate a .env with random secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_DOMAIN=localhost
APP_RELEASE=stable
WEB_URL=http://localhost
DEBUG=0
# Comma-separated origins allowed for CORS (e.g. https://plane.example.com)
CORS_ALLOWED_ORIGINS=http://localhost

# Django secret key — MUST change in production
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Gunicorn workers (1 per CPU core is a good baseline)
GUNICORN_WORKERS=1

# API rate limit
API_KEY_RATE_LIMIT=60/minute

# Max upload size in bytes (default 5 MB)
FILE_SIZE_LIMIT=5242880

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGHOST=plane-db
PGDATABASE=plane
# NOTE: Do NOT set DATABASE_URL here — compose constructs it dynamically
# from the individual variables above. Setting it here would override that.

# -----------------------------------------------------------------------------
# Redis (Valkey)
# -----------------------------------------------------------------------------
REDIS_HOST=plane-redis
REDIS_PORT=6379
# NOTE: Do NOT set REDIS_URL here — compose constructs it dynamically.

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_VHOST=plane
# NOTE: Do NOT set AMQP_URL here — compose constructs it dynamically.

# -----------------------------------------------------------------------------
# S3 / MinIO
# -----------------------------------------------------------------------------
USE_MINIO=1
AWS_ACCESS_KEY_ID=change-me-minio-access-key
AWS_SECRET_ACCESS_KEY=change-me-minio-secret-key
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads

# -----------------------------------------------------------------------------
# Live (real-time) server
# -----------------------------------------------------------------------------
LIVE_SERVER_SECRET_KEY=change-me-live-server-secret
API_BASE_URL=http://api:8000

# -----------------------------------------------------------------------------
# Proxy (Caddy)
# -----------------------------------------------------------------------------
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
SITE_ADDRESS=:80
# Set to private_ranges for production; 0.0.0.0/0 trusts ALL source IPs
TRUSTED_PROXIES=private_ranges

# TLS — uncomment and set for production HTTPS
# SITE_ADDRESS=plane.example.com
# CERT_EMAIL=email admin@example.com
# CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# -----------------------------------------------------------------------------
# Replica counts
# -----------------------------------------------------------------------------
WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
LIVE_REPLICAS=1
# NOTE: beat-worker is always 1 (hardcoded in compose) — multiple instances cause duplicate tasks
