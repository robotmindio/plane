# =============================================================================
# Plane Self-Hosted Configuration
# =============================================================================
# Copy this file to .env and update the values before starting.
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_DOMAIN=localhost
APP_RELEASE=stable
WEB_URL=http://localhost
DEBUG=0
CORS_ALLOWED_ORIGINS=http://localhost

# Django secret key — MUST change in production
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Gunicorn workers (1 per CPU core is a good baseline)
GUNICORN_WORKERS=1

# API rate limit
API_KEY_RATE_LIMIT=60/minute

# Max upload size in bytes (default 5 MB)
FILE_SIZE_LIMIT=5242880

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=plane
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGHOST=plane-db
PGDATABASE=plane
DATABASE_URL=postgresql://plane:change-me-postgres-password@plane-db/plane

# -----------------------------------------------------------------------------
# Redis (Valkey)
# -----------------------------------------------------------------------------
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=change-me-rabbitmq-password
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:change-me-rabbitmq-password@plane-mq:5672/plane

# -----------------------------------------------------------------------------
# S3 / MinIO
# -----------------------------------------------------------------------------
USE_MINIO=1
AWS_ACCESS_KEY_ID=change-me-minio-access-key
AWS_SECRET_ACCESS_KEY=change-me-minio-secret-key
AWS_REGION=
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
MINIO_ROOT_USER=change-me-minio-access-key
MINIO_ROOT_PASSWORD=change-me-minio-secret-key

# -----------------------------------------------------------------------------
# Live (real-time) server
# -----------------------------------------------------------------------------
LIVE_SERVER_SECRET_KEY=change-me-live-server-secret
API_BASE_URL=http://api:8000

# -----------------------------------------------------------------------------
# Proxy (Caddy)
# -----------------------------------------------------------------------------
LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443
SITE_ADDRESS=:80
TRUSTED_PROXIES=0.0.0.0/0

# TLS — uncomment and set for production HTTPS
# SITE_ADDRESS=${APP_DOMAIN}
# CERT_EMAIL=email admin@example.com
# CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# -----------------------------------------------------------------------------
# Replica counts
# -----------------------------------------------------------------------------
WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
# Beat scheduler MUST remain at 1 — multiple instances cause duplicate tasks
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1
